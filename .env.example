# .env.example — Pricewatch runtime configuration
#
# Copy this file to .env and adjust values for your environment.
# Variables without a default shown are optional.

# ── Database ──────────────────────────────────────────────────────────
# DATABASE_URL=sqlite:///pricewatch.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost/pricewatch

# ── Flask ─────────────────────────────────────────────────────────────
# FLASK_ENV=production
# SECRET_KEY=change-me-in-production

# ── Admin features ────────────────────────────────────────────────────
# Enable the admin sync endpoints (/api/admin/stores/sync etc.)
ENABLE_ADMIN_SYNC=true

# ── Scheduler autostart ───────────────────────────────────────────────
#
# SCHEDULER_ENABLED   — master switch; set to false to disable scheduler entirely
# SCHEDULER_AUTOSTART — set to false to keep scheduler enabled but prevent
#                       automatic background-thread startup at app init
# SCHEDULER_TICK_SECONDS — how often the scheduler loop runs (default: 30)
#
# When TESTING=True (set automatically by the test suite), scheduler autostart
# is always suppressed regardless of the values below.
#
SCHEDULER_ENABLED=true
SCHEDULER_AUTOSTART=true
SCHEDULER_TICK_SECONDS=30

